<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.sportsbrain.live-score-push</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/philiprassillier/sportsbrain/scripts/live_score_trigger.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/philiprassillier/sportsbrain</string>

    <!-- Alle 5 Min — Smart-Skip im Python-Script verhindert unnötige API-Calls -->
    <key>StartInterval</key>
    <integer>300</integer>

    <key>StandardOutPath</key>
    <string>/Users/philiprassillier/sportsbrain/results/launchd_live_score_push.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/philiprassillier/sportsbrain/results/launchd_live_score_push.log</string>

    <key>RunAtLoad</key>
    <false/>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/Library/Frameworks/Python.framework/Versions/3.13/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
